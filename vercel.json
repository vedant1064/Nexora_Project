{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://tera-backend-url.vercel.app/api/$1"
    },
    {
      "source": "/dashboard/(.*)",
      "destination": "/nexora-frontend/public/index.html"
    },
    {
      "source": "/((?!api|dashboard).*)",
      "destination": "/nexora-landing/index.html"
    }
  ]
}